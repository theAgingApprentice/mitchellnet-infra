# =============================================================================
# .env.example — MitchellNET environment variable template
#
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# The .env file is git-ignored and must NEVER be committed.
# This .env.example file IS committed — it documents every variable
# used across all MitchellNET services without exposing real values.
#
# Each service section matches the repo that consumes those variables.
# =============================================================================


# =============================================================================
# HOST
# =============================================================================
MITCHELLNET_HOST_IP=192.168.2.10
MITCHELLNET_DOMAIN=mitchellnet.local


# =============================================================================
# InternalWebServer — NGINX reverse proxy
# =============================================================================
# Paths to mkcert certificates on the Ubuntu host (mounted into NGINX container)
SSL_CERT_PATH=/home/andrew/services/mitchellnet-infra/ssl/certs/mitchellnet.local+3.pem
SSL_KEY_PATH=/home/andrew/services/mitchellnet-infra/ssl/certs/mitchellnet.local+3-key.pem


# =============================================================================
# fitness-tracker — Flask + MariaDB
# =============================================================================
# MariaDB credentials (used by both mariadb container and Flask backend)
FITNESS_DB_HOST=fitness-tracker-mariadb
FITNESS_DB_PORT=3306
FITNESS_DB_NAME=fitness_tracker_prod
FITNESS_DB_USER=fitness_user
FITNESS_DB_PASSWORD=change_me

# Flask
FITNESS_FLASK_SECRET_KEY=change_me
FITNESS_FLASK_ENV=production
FITNESS_FLASK_DEBUG=0


# =============================================================================
# bench-instrument-service — FastAPI LXI instrument API
# =============================================================================
# Instrument IPs on the lab network
BIS_OSCILLOSCOPE_IP=192.168.2.x
BIS_SIGGEN_IP=192.168.2.x
BIS_MULTIMETER_IP=192.168.2.x
BIS_PSU_IP=192.168.2.x

# Default SCPI timeout in seconds
BIS_SCPI_TIMEOUT=5

# FastAPI
BIS_LOG_LEVEL=info


# =============================================================================
# mitchellnet-monitoring — Grafana + Prometheus + InfluxDB + LibreNMS
# =============================================================================
# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
GRAFANA_SECRET_KEY=change_me
GRAFANA_ROOT_URL=https://mitchellnet.local/grafana/

# Prometheus (no auth by default — access via NGINX only)
# No secrets required for basic setup.

# InfluxDB
INFLUXDB_DB=librenms
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=change_me
INFLUXDB_USER=telegraf
INFLUXDB_USER_PASSWORD=change_me

# LibreNMS
LIBRENMS_DB_HOST=librenms-mariadb
LIBRENMS_DB_NAME=librenms
LIBRENMS_DB_USER=librenms
LIBRENMS_DB_PASSWORD=change_me
LIBRENMS_DB_ROOT_PASSWORD=change_me


# =============================================================================
# mitchellnet-iot — Mosquitto MQTT broker
# =============================================================================
# Mosquitto (anonymous access is the current default; add credentials here
# before enabling authentication in mosquitto.conf)
MQTT_BROKER_HOST=192.168.2.10
MQTT_BROKER_PORT=1883
# MQTT_USERNAME=change_me
# MQTT_PASSWORD=change_me


# =============================================================================
# mitchellnet-device-registry — FastAPI + SQLite
# =============================================================================
REGISTRY_DB_PATH=/data/registry.db
REGISTRY_LOG_LEVEL=info
REGISTRY_MQTT_BROKER=mosquitto
REGISTRY_MQTT_PORT=1883


# =============================================================================
# GitHub Actions deploy (stored as GitHub repo secrets, not in this file)
# These are documented here for reference only.
# =============================================================================
# PROD_HOST=192.168.2.10
# PROD_USER=andrew
# PROD_SSH_KEY=<private key — GitHub secret only, never in any file>
