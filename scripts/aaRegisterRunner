#!/bin/bash
# Guides the user through registering a new GitHub Actions self-hosted runner.

REPO_NAME="$1"

if [ -z "$REPO_NAME" ]; then
    echo "Usage: aaRegisterRunner <repo-name>"
    echo ""
    echo "  repo-name  The GitHub repository name (e.g. fitness-tracker)"
    exit 1
fi

RUNNER_DIR="/home/andrew/actions-runner-${REPO_NAME}"
GITHUB_ORG="theAgingApprentice"

echo "============================================================"
echo "  GitHub Actions Runner Setup: ${REPO_NAME}"
echo "============================================================"
echo ""
echo "Runner directory: ${RUNNER_DIR}"
echo ""

echo "Step 1: Create the runner directory"
echo ""
echo "  mkdir -p ${RUNNER_DIR} && cd ${RUNNER_DIR}"
echo ""

echo "Step 2: Download the latest runner package"
echo ""
echo "  curl -o actions-runner-linux-x64.tar.gz -L \\"
echo "    https://github.com/actions/runner/releases/latest/download/actions-runner-linux-x64-\$(curl -s https://api.github.com/repos/actions/runner/releases/latest | grep tag_name | cut -d'\"' -f4 | sed 's/v//').tar.gz"
echo "  tar xzf ./actions-runner-linux-x64.tar.gz"
echo ""

echo "Step 3: Get your registration token from GitHub, then run:"
echo ""
echo "  ./config.sh --url https://github.com/${GITHUB_ORG}/${REPO_NAME} --token YOUR_TOKEN"
echo ""
echo "  Get the token at:"
echo "  https://github.com/${GITHUB_ORG}/${REPO_NAME}/settings/actions/runners/new"
echo ""

echo "Step 4: Install and start as a service:"
echo ""
echo "  sudo ./svc.sh install && sudo ./svc.sh start"
echo ""
echo "============================================================"
echo "  Verify the runner appears at:"
echo "  https://github.com/${GITHUB_ORG}/${REPO_NAME}/settings/actions/runners"
echo "============================================================"
