#!/bin/bash
# Creates a branch, stages all changes, commits, pushes, and prints a PR link.

set -e

BRANCH_NAME="$1"
COMMIT_MSG="${2:-Promote outstanding changes to ${BRANCH_NAME}}"

if [ -z "$BRANCH_NAME" ]; then
    echo "Usage: aaGitPromote <branch-name> [commit-message]"
    echo ""
    echo "  branch-name     Required. Name of the branch to create and push."
    echo "  commit-message  Optional. Defaults to 'Promote outstanding changes to <branch-name>'."
    exit 1
fi

REMOTE_URL=$(git remote get-url origin 2>/dev/null || echo "")
REPO_PATH=""
if [[ "$REMOTE_URL" =~ github\.com[:/](.+/.+)(\.git)?$ ]]; then
    REPO_PATH="${BASH_REMATCH[1]%.git}"
fi

echo "Creating branch: $BRANCH_NAME"
git checkout -b "$BRANCH_NAME"

echo "Staging all changes..."
git add -A

echo "Committing: $COMMIT_MSG"
git commit -m "$COMMIT_MSG"

echo "Pushing to origin/$BRANCH_NAME..."
git push -u origin "$BRANCH_NAME"

if [ -n "$REPO_PATH" ]; then
    echo ""
    echo "Open a pull request:"
    echo "  https://github.com/${REPO_PATH}/compare/${BRANCH_NAME}?expand=1"
fi
