#!/usr/bin/env bash
set -euo pipefail

REPO_NAME="${1:-}"

if [[ -z "$REPO_NAME" ]]; then
  echo "Usage: aaNewService <repo-name>"
  echo "Example: aaNewService fitness-tracker"
  exit 1
fi

echo ""
echo "=================================================="
echo " MitchellNET New Service Setup: $REPO_NAME"
echo "=================================================="
echo ""

# Step 1 — Create the GitHub repo
echo "Step 1 — Create the GitHub repository"
echo "--------------------------------------"
echo "Create a new PUBLIC repository at:"
echo ""
echo "  https://github.com/theAgingApprentice/${REPO_NAME}"
echo ""
echo "Make sure it is set to PUBLIC."
echo ""
read -rp "Press Enter when done..."
echo ""

# Step 2 — Branch protection
echo "Step 2 — Add branch protection for main"
echo "----------------------------------------"
echo "Go to:"
echo ""
echo "  https://github.com/theAgingApprentice/${REPO_NAME}/settings/branches"
echo ""
echo "Add a classic branch protection rule for the pattern: main"
echo ""
echo "Required settings:"
echo "  [x] Require a pull request before merging"
echo "  [x] Require status checks to pass before merging"
echo "  [ ] Do NOT require approving reviews"
echo "  [ ] Do not allow bypassing the above settings"
echo ""
read -rp "Press Enter when done..."
echo ""

# Step 3 — Runner registration
echo "Step 3 — Register the GitHub Actions self-hosted runner"
echo "--------------------------------------------------------"
echo "On the Ubuntu server, run the following commands:"
echo ""
echo "  mkdir -p /home/andrew/actions-runner-${REPO_NAME}"
echo "  cd /home/andrew/actions-runner-${REPO_NAME}"
echo ""
echo "  curl -o actions-runner-linux-x64-2.319.1.tar.gz -L \\"
echo "    https://github.com/actions/runner/releases/download/v2.319.1/actions-runner-linux-x64-2.319.1.tar.gz"
echo ""
echo "  tar xzf ./actions-runner-linux-x64-2.319.1.tar.gz"
echo ""
echo "  ./config.sh \\"
echo "    --url https://github.com/theAgingApprentice/${REPO_NAME} \\"
echo "    --token <YOUR_RUNNER_TOKEN>"
echo ""
echo "Get the runner token from:"
echo "  https://github.com/theAgingApprentice/${REPO_NAME}/settings/actions/runners/new"
echo ""
echo "--- Service installation ---"
echo ""
echo "Run these from inside the runner directory."
echo "The runner will not start automatically until you do."
echo ""
echo "  sudo ./svc.sh install"
echo "  sudo ./svc.sh start"
echo ""
echo "Alternatively, run: aaRegisterRunner ${REPO_NAME}"
echo ""
read -rp "Press Enter when done..."
echo ""

# Step 4 — Clone and open locally
echo "Step 4 — Clone the repo and open in VS Code"
echo "--------------------------------------------"
echo "On your Mac Studio, run:"
echo ""
echo "  cd ~/Documents/visualStudioCode/newProjectStructure"
echo "  git clone https://github.com/theAgingApprentice/${REPO_NAME}.git"
echo "  code ${REPO_NAME}"
echo ""
read -rp "Press Enter when done..."
echo ""

# Step 5 — Checklist summary
echo "Step 5 — Checklist summary"
echo "--------------------------"
echo ""
echo "Completed:"
echo "  [x] GitHub repo created (public)"
echo "  [x] Branch protection rule added for main"
echo "  [x] Self-hosted runner registered and running"
echo "  [x] Repo cloned locally and opened in VS Code"
echo ""
echo "Still needs to be done manually:"
echo "  [ ] Add Dockerfile"
echo "  [ ] Add docker-compose.yml"
echo "  [ ] Add .github/workflows/deploy.yml"
echo "        (use bench-instrument-service as the reference pattern)"
echo "  [ ] Add .env.example"
echo "  [ ] Add README.md"
echo ""
echo "Setup complete for: $REPO_NAME"
echo ""
